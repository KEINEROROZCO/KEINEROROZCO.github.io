# CONFIGURACIÓN DE ENTORNO - LUMINA STORE
# Renombra este archivo a .env e ingresa tus claves reales.

# Resend API Key (Para envío de correos)
# Consíguela en: https://resend.com
RESEND_API_KEY=re_your_key_here

# Unsplash Access Key (Opcional, para mayor cuota de imágenes)
# Consíguela en: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# Configuración del Remitente
STORE_EMAIL=confirmaciones@tu-dominio.com
