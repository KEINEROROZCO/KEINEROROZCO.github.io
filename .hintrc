{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/html": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "scrollbar-width"
        ]
      }
    ],
    "no-inline-styles": "off",
    "axe/name-role-value": [
      "default",
      {
        "link-name": "off",
        "button-name": "off"
      }
    ],
    "disown-opener": "off",
    "button-type": "off",
    "axe/forms": "off",
    "axe/text-alternatives": "off"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not chrome <= 112",
    "not ios_saf <= 26.4",
    "not safari <= 26.4",
    "not samsung <= 29"
  ]
}